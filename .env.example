AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence-resource.cognitiveservices.azure.com
AZURE_DOC_INTELLIGENCE_API_KEY=your_doc_intelligence_api_key
AZURE_DOC_INTELLIGENCE_API_VERSION=2024-02-29-preview
# Production-intended auth posture (recommended):
NUDGE_AUTH_MODE=token
NUDGE_TOKEN_SIGNING_KEY=replace_with_strong_signing_secret
NUDGE_TOKEN_ISSUER=nudge
NUDGE_TOKEN_AUDIENCE=nudge-client
NUDGE_REQUIRED_SCOPE=nudge.api
NUDGE_ALLOW_LEGACY_API_KEY=false
NUDGE_REVOKED_TOKEN_JTIS=
# Internal/dev compatibility fallback only (do not use as final production model):
NUDGE_BACKEND_API_KEY=replace_with_shared_backend_api_key
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_ACTION_REQUESTS=30
RATE_LIMIT_OCR_REQUESTS=10
RATE_LIMIT_BACKEND=redis
REDIS_URL=
MAX_REQUEST_BODY_BYTES=10485760
PORT=8000

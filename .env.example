AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence-resource.cognitiveservices.azure.com
AZURE_DOC_INTELLIGENCE_API_KEY=your_doc_intelligence_api_key
AZURE_DOC_INTELLIGENCE_API_VERSION=2024-11-30
OCR_POLL_TIMEOUT_SECONDS=25
# Production-intended auth posture (recommended):
NUDGE_AUTH_MODE=token
NUDGE_TOKEN_SIGNING_KEY=replace_with_strong_signing_secret
NUDGE_AUTH_ISSUER_ENABLED=true
# Strong secret used only to bootstrap initial token issuance at /auth/token.
# Rotate on schedule and after any suspected exposure.
NUDGE_AUTH_BOOTSTRAP_KEY=replace_with_strong_bootstrap_key
NUDGE_ACCESS_TOKEN_TTL_SECONDS=900
NUDGE_REFRESH_TOKEN_TTL_SECONDS=2592000
NUDGE_TOKEN_ISSUER=nudge
NUDGE_TOKEN_AUDIENCE=nudge-client
NUDGE_REQUIRED_SCOPE=nudge.api
NUDGE_ALLOW_LEGACY_API_KEY=false
NUDGE_REVOKED_TOKEN_JTIS=
# Comma or newline-separated paid license keys (POST /auth/activate).
NUDGE_CUSTOMER_LICENSE_KEYS=
# Optional beta/trial keys for hand-picked testers (no payment). Same UX as paid keys; JWT subject uses tlic: prefix.
NUDGE_TRIAL_LICENSE_KEYS=
# Per-IP rate limit for /auth/activate (requests per minute).
NUDGE_ACTIVATION_RATE_LIMIT_PER_MINUTE=20
# Bind each license key to one device_id (recommended for paid seats). Set false for lab/testing only.
NUDGE_LICENSE_DEVICE_BINDING_ENABLED=true
# Internal/dev compatibility fallback only (do not use as final production model):
NUDGE_BACKEND_API_KEY=replace_with_shared_backend_api_key
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_ACTION_REQUESTS=30
RATE_LIMIT_OCR_REQUESTS=10
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_FAILURE_MODE=fail_closed
TRUSTED_PROXY_CIDRS=
# Keep false in production. Use true only in controlled internal tests.
TRUSTED_PROXY_ALLOW_INSECURE_ANY=false
TOKEN_STATE_BACKEND=redis
TOKEN_STATE_PREFIX=nudge:auth
REDIS_URL=
MAX_REQUEST_BODY_BYTES=10485760
LEADS_DB_PATH=data/nudge_leads.db
ADMIN_DASHBOARD_ENABLED=false
ADMIN_DASHBOARD_USERNAME=
ADMIN_DASHBOARD_PASSWORD=
PORT=8000

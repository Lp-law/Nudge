# Local Windows demo — copy to repo root as `.env` then fill Azure (required for AI/OCR).
#   Copy-Item env.local.sample .env
#
# Fastest client path: legacy API key (no activation dialog).
#   Run: .\scripts\Run-LocalClient.ps1
# Full activation path: omit client API key; use Run-LocalClient.ps1 -UseActivation
#   Trial key below must match what you type in the Hebrew activation dialog.

AZURE_OPENAI_API_KEY=PASTE_YOUR_AZURE_OPENAI_KEY
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=PASTE_YOUR_DEPLOYMENT_NAME

AZURE_DOC_INTELLIGENCE_ENDPOINT=https://YOUR_DOC_RESOURCE.cognitiveservices.azure.com
AZURE_DOC_INTELLIGENCE_API_KEY=PASTE_YOUR_DOC_INTEL_KEY
AZURE_DOC_INTELLIGENCE_API_VERSION=2024-02-29-preview

OCR_POLL_TIMEOUT_SECONDS=25

# Dev auth: API key on client + server (same string). No Redis required.
NUDGE_AUTH_MODE=token_or_api_key
NUDGE_ALLOW_LEGACY_API_KEY=true
NUDGE_BACKEND_API_KEY=local-dev-shared-api-key-change-me
NUDGE_TOKEN_SIGNING_KEY=local-dev-jwt-signing-secret-min-32-chars-ok
NUDGE_AUTH_ISSUER_ENABLED=true
NUDGE_AUTH_BOOTSTRAP_KEY=local-dev-bootstrap-key-min-24-chars-x
NUDGE_ACCESS_TOKEN_TTL_SECONDS=900
NUDGE_REFRESH_TOKEN_TTL_SECONDS=2592000
NUDGE_TOKEN_ISSUER=nudge
NUDGE_TOKEN_AUDIENCE=nudge-client
NUDGE_REQUIRED_SCOPE=nudge.api
NUDGE_REVOKED_TOKEN_JTIS=

NUDGE_CUSTOMER_LICENSE_KEYS=
NUDGE_TRIAL_LICENSE_KEYS=local-trial-key-for-activation-flow-1
NUDGE_ACTIVATION_RATE_LIMIT_PER_MINUTE=20
NUDGE_LICENSE_DEVICE_BINDING_ENABLED=false

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_ACTION_REQUESTS=30
RATE_LIMIT_OCR_REQUESTS=10
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_FAILURE_MODE=fail_closed
TRUSTED_PROXY_CIDRS=127.0.0.1/32
TOKEN_STATE_BACKEND=memory
TOKEN_STATE_PREFIX=nudge:local
REDIS_URL=
MAX_REQUEST_BODY_BYTES=10485760
LEADS_DB_PATH=data/nudge_leads.db
ADMIN_DASHBOARD_ENABLED=false
ADMIN_DASHBOARD_USERNAME=
ADMIN_DASHBOARD_PASSWORD=
PORT=8000
